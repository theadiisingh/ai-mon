# AI MON - Environment Configuration Example
# Copy this file to .env and update the values

# Application
APP_NAME=AI MON
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL recommended for production)
# SQLite: sqlite+aiosqlite:///./aimon.db
DATABASE_URL=postgresql+asyncpg://aimon:aimon123@localhost:5432/aimon

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# AI/LLM (Optional)
OPENAI_API_KEY=
AI_MODEL=gpt-4
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# Monitoring
MONITORING_INTERVAL_SECONDS=60
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@aimon.local

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO
