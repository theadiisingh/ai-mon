# AI MON Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED FOR PRODUCTION
# =============================================================================

# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-min-32-chars

# Set to 'production' for production deployments
ENVIRONMENT=production

# Set to 'false' for production (error details hidden)
DEBUG=false

# =============================================================================
# OPTIONAL - AI/LLM Configuration
# =============================================================================

# OpenAI API Key (optional - AI features will use mock responses if not set)
# OPENAI_API_KEY=sk-...

# =============================================================================
# OPTIONAL - Email Configuration
# =============================================================================

# SMTP Email Settings (for notifications)
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# =============================================================================
# OPTIONAL - Database
# =============================================================================

# For production, consider using PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/aimon

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# For local development, uncomment:
# ENVIRONMENT=development
# DEBUG=true

