# AI MON Environment Configuration
# Copy this file to .env and update the values

# App
APP_NAME="AI MON"
APP_VERSION="1.0.0"
DEBUG=True

# Database - Use PostgreSQL for production
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aimon"

# JWT Authentication
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI/LLM Configuration
# Leave empty to use mock AI responses (for development/testing)
OPENAI_API_KEY=""
AI_MODEL="gpt-4"
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# Monitoring
MONITORING_INTERVAL_SECONDS=60
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30

# Email (SMTP) - Leave empty to disable email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="ai-mon@example.com"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
